{
  "name": "flexphish",
  "version": "1.3.1",
  "engines": {
    "node": ">=20.17.0 <21.0.0",
    "pnpm": ">=10.0.0 <11.0.0"
  },
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "test:cov": "vitest run --coverage",
    "format": "pnpm dlx @biomejs/biome format --write ./src",
    "lint": "pnpm dlx @biomejs/biome lint ./src",
    "lint:fix": "pnpm dlx @biomejs/biome lint --write ./src",
    "check": "pnpm dlx @biomejs/biome check --write ./src",
    "check:all": "pnpm check && pnpm test:cov"
  },
  "private": true,
  "dependencies": {
    "@acrodata/code-editor": "^0.5.1",
    "@angular/animations": "^20.0.0",
    "@angular/cdk": "^20.0.1",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language-data": "^6.5.1",
    "@fontsource/fira-mono": "^5.2.6",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/poppins": "^5.2.6",
    "@fortawesome/angular-fontawesome": "^3.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@ng-select/ng-select": "^15.0.2",
    "@ngneat/elf": "^2.5.1",
    "ansi_up": "^6.0.6",
    "apexcharts": "^5.10.3",
    "chart.js": "^4.4.9",
    "compare-versions": "^6.1.1",
    "highlight.js": "^11.11.1",
    "jwt-decode": "^4.0.0",
    "lucide-angular": "^0.511.0",
    "ng2-charts": "^8.0.0",
    "ngx-highlightjs": "^14.0.0",
    "normalize-url": "^8.0.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
